generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Venue {
  id               String       @id @default(cuid())
  venueName        String
  addressLine1     String?
  addressLine2     String?
  city             String?
  stateProvince    String?
  country          String?
  postalCode       String?
  phoneNumber      String?
  mapLink          String?
  showOnVenuesPage Boolean      @default(true)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  logoUrl          String?
  matches          Match[]
  tournaments      Tournament[]

  @@index([venueName])
}

model Season {
  id          String       @id @default(cuid())
  seasonName  String       @unique
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  leagueId    String?
  League      League?      @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  tournaments Tournament[]

  @@index([leagueId])
}

model Tournament {
  id              String            @id @default(cuid())
  seasonId        String
  venueId         String?
  tournamentName  String
  participantType ParticipantType
  snookerFormat   SnookerFormat?
  registrationDeadline DateTime?
  startDate       DateTime?
  endDate         DateTime?
  status          TournamentStatus  @default(DRAFT)
  isPublished     Boolean           @default(false)
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  matches         Match[]
  season          Season            @relation(fields: [seasonId], references: [id])
  venue           Venue?            @relation(fields: [venueId], references: [id])
  entries         TournamentEntry[]
  stages          TournamentStage[]

  @@index([seasonId])
  @@index([venueId])
  @@index([tournamentName])
}

model TournamentStage {
  id           String              @id @default(cuid())
  tournamentId String
  stageName    String
  stageType    TournamentStageType
  sequence     Int
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  matches      Match[]
  rounds       StageRound[]
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, sequence])
  @@unique([tournamentId, stageName])
  @@index([tournamentId])
}

model StageRound {
  id                String            @id @default(cuid())
  tournamentStageId String
  roundName         String
  roundType         StageRoundType
  sequence          Int
  matchesPerPairing Int               @default(1)
  bestOfFrames      Int?
  snookerFormat     SnookerFormat?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  advancePerGroup   Int?
  groupCount        Int?
  playersPerGroup   Int?
  matches           Match[]
  tournamentStage   TournamentStage   @relation(fields: [tournamentStageId], references: [id], onDelete: Cascade)
  groups            TournamentGroup[]

  @@unique([tournamentStageId, sequence])
  @@unique([tournamentStageId, roundName])
  @@index([tournamentStageId])
}

model TournamentGroup {
  id           String             @id @default(cuid())
  stageRoundId String
  groupName    String
  sequence     Int
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  participants GroupParticipant[]
  matches      Match[]
  stageRound   StageRound         @relation(fields: [stageRoundId], references: [id], onDelete: Cascade)

  @@unique([stageRoundId, sequence])
  @@unique([stageRoundId, groupName])
  @@index([stageRoundId])
}

model User {
  id                         String                   @id @default(cuid())
  username                   String?
  normalizedUsername         String?                  @unique
  email                      String?                  @unique
  normalizedEmail            String?                  @unique
  emailVerifiedAt            DateTime?
  passwordHash               String?
  passwordSetAt              DateTime?
  phoneNumber                String?
  registrationStatus         RegistrationStatus       @default(INACTIVE)
  isLoginEnabled             Boolean                  @default(false)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  approvedMatches            Match[]                  @relation("MatchApprovedByUser")
  enteredMatches             Match[]                  @relation("MatchEnteredByUser")
  updatedMatches             Match[]                  @relation("MatchUpdatedByUser")
  submittedMatchResultSubmissions MatchResultSubmission[] @relation("MatchResultSubmissionSubmittedByUser")
  approvedMatchResultSubmissions  MatchResultSubmission[] @relation("MatchResultSubmissionApprovedByUser")
  disputedMatchResultSubmissions  MatchResultSubmission[] @relation("MatchResultSubmissionDisputedByUser")
  player                     Player?
  authAccounts               AuthAccount[]
  targetInvitations          Invitation[]             @relation("InvitationTargetUser")
  createdInvitations         Invitation[]             @relation("InvitationCreatedByUser")
  acceptedInvitations        Invitation[]             @relation("InvitationAcceptedByUser")
  userRoles                  UserRole[]
  roleAssignments            UserRoleAssignment[]
  accessGroupMemberships     AccessGroupMembership[]
  grantedRoleAssignments     UserRoleAssignment[]     @relation("RoleAssignmentGrantedByUser")
  grantedAccessGroupRoleAssignments AccessGroupRoleAssignment[] @relation("AccessGroupRoleAssignmentGrantedByUser")
  permissionOverrides        UserPermissionOverride[]
  grantedPermissionOverrides UserPermissionOverride[] @relation("PermissionOverrideGrantedByUser")
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]

  @@index([registrationStatus])
}

model Player {
  id            String                  @id @default(cuid())
  userId        String?                 @unique
  firstName     String
  middleInitial String?
  lastName      String
  eloRating     Int                     @default(1500)
  dateOfBirth   DateTime?
  emailAddress  String?
  phoneNumber   String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  stateProvince String?
  country       String?
  postalCode    String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  photoUrl      String?
  user          User?                   @relation(fields: [userId], references: [id])
  breaks        PlayerBreak[]
  entryMembers  TournamentEntryMember[]
  eloHistory    PlayerEloHistory[]
  submittedMatchResultSubmissions MatchResultSubmission[] @relation("MatchResultSubmissionSubmittedByPlayer")
  invitations   Invitation[]

  @@index([lastName, firstName])
  @@index([emailAddress])
}

model Role {
  id                  String               @id @default(cuid())
  roleKey             String               @unique
  roleName            String               @unique
  description         String?
  isSystemRole        Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  userRoles           UserRole[]
  rolePermissions     RolePermission[]
  userRoleAssignments UserRoleAssignment[]
  accessGroupRoleAssignments AccessGroupRoleAssignment[]
}

model AccessGroup {
  id          String                @id @default(cuid())
  groupName   String                @unique
  description String?
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  memberships AccessGroupMembership[]
  roleAssignments AccessGroupRoleAssignment[]

  @@index([isActive])
}

model AccessGroupMembership {
  id        String      @id @default(cuid())
  groupId   String
  userId    String
  createdAt DateTime    @default(now())
  group     AccessGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model AuthAccount {
  id                      String       @id @default(cuid())
  userId                  String
  provider                AuthProvider
  providerAccountId       String
  providerEmail           String?
  providerEmailNormalized String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([providerEmailNormalized])
}

model Invitation {
  id               String            @id @default(cuid())
  playerId         String?
  userId           String?
  email            String
  normalizedEmail  String
  purpose          InvitationPurpose @default(ACCOUNT_SETUP)
  tokenHash        String            @unique
  status           InvitationStatus  @default(PENDING)
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  createdByUserId  String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  player           Player?           @relation(fields: [playerId], references: [id], onDelete: SetNull)
  targetUser       User?             @relation("InvitationTargetUser", fields: [userId], references: [id], onDelete: SetNull)
  acceptedByUser   User?             @relation("InvitationAcceptedByUser", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  createdByUser    User              @relation("InvitationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([playerId])
  @@index([userId])
  @@index([normalizedEmail])
  @@index([status])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id              String    @id @default(cuid())
  userId          String?
  email           String
  normalizedEmail String
  tokenHash       String    @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([normalizedEmail])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Permission {
  id                      String                   @id @default(cuid())
  permissionKey           String                   @unique
  permissionName          String
  description             String?
  category                String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  rolePermissions         RolePermission[]
  userPermissionOverrides UserPermissionOverride[]

  @@index([category])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model AccessGroupRoleAssignment {
  id              String              @id @default(cuid())
  groupId          String
  roleId           String
  scopeType        AssignmentScopeType
  scopeId          String              @default("")
  grantedByUserId  String?
  createdAt        DateTime            @default(now())
  expiresAt        DateTime?
  group            AccessGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role             Role                @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedByUser    User?               @relation("AccessGroupRoleAssignmentGrantedByUser", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, roleId, scopeType, scopeId])
  @@index([groupId])
  @@index([roleId])
  @@index([scopeType, scopeId])
}

model UserRoleAssignment {
  id              String              @id @default(cuid())
  userId          String
  roleId          String
  scopeType       AssignmentScopeType
  scopeId         String              @default("")
  grantedByUserId String?
  createdAt       DateTime            @default(now())
  expiresAt       DateTime?
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role                @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedByUser   User?               @relation("RoleAssignmentGrantedByUser", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeId])
}

model UserPermissionOverride {
  id              String              @id @default(cuid())
  userId          String
  permissionId    String
  scopeType       AssignmentScopeType
  scopeId         String              @default("")
  effect          PermissionEffect
  reason          String?
  grantedByUserId String?
  createdAt       DateTime            @default(now())
  expiresAt       DateTime?
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission      Permission          @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByUser   User?               @relation("PermissionOverrideGrantedByUser", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId, scopeType, scopeId])
  @@index([userId])
  @@index([permissionId])
  @@index([scopeType, scopeId])
}

model TournamentEntry {
  id            String                  @id @default(cuid())
  tournamentId  String
  entryName     String?
  seedNumber    Int?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  groupLinks    GroupParticipant[]
  awayMatches   Match[]                 @relation("MatchAwayEntry")
  homeMatches   Match[]                 @relation("MatchHomeEntry")
  winnerMatches Match[]                 @relation("MatchWinnerEntry")
  submittedMatchResultSubmissions MatchResultSubmission[] @relation("MatchResultSubmissionSubmittedByEntry")
  targetMatchResultSubmissions    MatchResultSubmission[] @relation("MatchResultSubmissionTargetEntry")
  wonMatchResultSubmissions       MatchResultSubmission[] @relation("MatchResultSubmissionWinnerEntry")
  matchFrames   MatchFrame[]
  tournament    Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members       TournamentEntryMember[]

  @@index([tournamentId])
  @@index([seedNumber])
}

model TournamentEntryMember {
  id                String          @id @default(cuid())
  tournamentEntryId String
  playerId          String
  createdAt         DateTime        @default(now())
  player            Player          @relation(fields: [playerId], references: [id])
  tournamentEntry   TournamentEntry @relation(fields: [tournamentEntryId], references: [id], onDelete: Cascade)

  @@unique([tournamentEntryId, playerId])
  @@index([tournamentEntryId])
  @@index([playerId])
}

model GroupParticipant {
  id                String          @id @default(cuid())
  tournamentGroupId String
  tournamentEntryId String
  createdAt         DateTime        @default(now())
  tournamentEntry   TournamentEntry @relation(fields: [tournamentEntryId], references: [id], onDelete: Cascade)
  tournamentGroup   TournamentGroup @relation(fields: [tournamentGroupId], references: [id], onDelete: Cascade)

  @@unique([tournamentGroupId, tournamentEntryId])
  @@index([tournamentGroupId])
  @@index([tournamentEntryId])
}

model Match {
  id                String           @id @default(cuid())
  tournamentId      String
  tournamentStageId String
  stageRoundId      String
  tournamentGroupId String?
  venueId           String?
  matchDate         DateTime?
  matchTime         String?
  scheduleStatus    ScheduleStatus   @default(TBC)
  matchStatus       MatchStatus      @default(SCHEDULED)
  homeEntryId       String
  awayEntryId       String
  winnerEntryId     String?
  bestOfFrames      Int?
  snookerFormat     SnookerFormat?
  homeScore         Int?
  awayScore         Int?
  internalNote      String?
  publicNote        String?
  resultSubmittedAt DateTime?
  approvedAt        DateTime?
  approvedByUserId  String?
  enteredByUserId   String?
  updatedByUserId   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  approvedByUser    User?            @relation("MatchApprovedByUser", fields: [approvedByUserId], references: [id])
  awayEntry         TournamentEntry  @relation("MatchAwayEntry", fields: [awayEntryId], references: [id])
  enteredByUser     User?            @relation("MatchEnteredByUser", fields: [enteredByUserId], references: [id])
  homeEntry         TournamentEntry  @relation("MatchHomeEntry", fields: [homeEntryId], references: [id])
  stageRound        StageRound       @relation(fields: [stageRoundId], references: [id], onDelete: Cascade)
  tournamentGroup   TournamentGroup? @relation(fields: [tournamentGroupId], references: [id])
  tournament        Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentStage   TournamentStage  @relation(fields: [tournamentStageId], references: [id], onDelete: Cascade)
  updatedByUser     User?            @relation("MatchUpdatedByUser", fields: [updatedByUserId], references: [id])
  venue             Venue?           @relation(fields: [venueId], references: [id])
  winnerEntry       TournamentEntry? @relation("MatchWinnerEntry", fields: [winnerEntryId], references: [id])
  frames            MatchFrame[]
  resultSubmissions MatchResultSubmission[]
  playerEloHistory  PlayerEloHistory[]

  @@index([tournamentId])
  @@index([tournamentStageId])
  @@index([stageRoundId])
  @@index([tournamentGroupId])
  @@index([venueId])
  @@index([homeEntryId])
  @@index([awayEntryId])
  @@index([winnerEntryId])
  @@index([approvedByUserId])
  @@index([enteredByUserId])
  @@index([updatedByUserId])
}

model MatchResultSubmission {
  id                  String                      @id @default(cuid())
  matchId             String
  submittedByUserId   String
  submittedByPlayerId String
  submittedByEntryId  String
  targetEntryId       String
  winnerEntryId       String?
  homeScore           Int
  awayScore           Int
  status              MatchResultSubmissionStatus @default(PENDING)
  summaryNote         String?
  proposedMatchDate   DateTime?
  proposedMatchTime   String?
  proposedEndedAt     DateTime?
  submittedAt         DateTime                    @default(now())
  approvedAt          DateTime?
  approvedByUserId    String?
  disputedAt          DateTime?
  disputedByUserId    String?
  disputeReason       String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  match               Match                       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedByUser     User                        @relation("MatchResultSubmissionSubmittedByUser", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  submittedByPlayer   Player                      @relation("MatchResultSubmissionSubmittedByPlayer", fields: [submittedByPlayerId], references: [id], onDelete: Cascade)
  submittedByEntry    TournamentEntry             @relation("MatchResultSubmissionSubmittedByEntry", fields: [submittedByEntryId], references: [id], onDelete: Cascade)
  targetEntry         TournamentEntry             @relation("MatchResultSubmissionTargetEntry", fields: [targetEntryId], references: [id], onDelete: Cascade)
  winnerEntry         TournamentEntry?            @relation("MatchResultSubmissionWinnerEntry", fields: [winnerEntryId], references: [id], onDelete: SetNull)
  approvedByUser      User?                       @relation("MatchResultSubmissionApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  disputedByUser      User?                       @relation("MatchResultSubmissionDisputedByUser", fields: [disputedByUserId], references: [id], onDelete: SetNull)
  frames              MatchResultSubmissionFrame[]

  @@index([matchId])
  @@index([status])
  @@index([submittedByPlayerId])
  @@index([submittedByEntryId])
  @@index([targetEntryId])
  @@index([submittedAt])
  @@index([approvedByUserId])
  @@index([disputedByUserId])
}

model MatchResultSubmissionFrame {
  id            String                @id @default(cuid())
  submissionId  String
  frameNumber   Int
  homeHighBreak Int?
  awayHighBreak Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  submission    MatchResultSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, frameNumber])
  @@index([submissionId])
}

model PlayerEloHistory {
  id                String   @id @default(cuid())
  playerId          String
  matchId           String
  ratingBefore      Int
  ratingAfter       Int
  ratingChange      Int
  matchesPlayed     Int
  expectedScore     Float
  actualScore       Float
  opponentAverage   Float
  matchDate         DateTime?
  createdAt         DateTime @default(now())
  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, matchId])
  @@index([playerId, matchDate])
  @@index([matchId])
}

model MatchFrame {
  id            String           @id @default(cuid())
  matchId       String
  frameNumber   Int
  winnerEntryId String?
  homePoints    Int?
  awayPoints    Int?
  homeHighBreak Int?
  awayHighBreak Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  match         Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerEntry   TournamentEntry? @relation(fields: [winnerEntryId], references: [id])
  breaks        PlayerBreak[]

  @@unique([matchId, frameNumber])
  @@index([matchId])
  @@index([winnerEntryId])
}

model PlayerBreak {
  id           String     @id @default(cuid())
  matchFrameId String
  playerId     String
  breakValue   Int
  createdAt    DateTime   @default(now())
  matchFrame   MatchFrame @relation(fields: [matchFrameId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([matchFrameId])
  @@index([playerId])
  @@index([breakValue])
}

model League {
  id          String   @id @default(cuid())
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  isActive    Boolean  @default(true)
  leagueName  String   @unique
  Season      Season[]
}

model NewsArticle {
  id              String               @id @default(cuid())
  title           String
  slug            String               @unique
  excerpt         String?
  contentHtml     String
  contentJson     Json?
  coverImageUrl   String?
  status          NewsStatus           @default(DRAFT)
  publishedAt     DateTime?
  showOnHomePage  Boolean              @default(false)
  homePlacement   HomeNewsPlacement?
  homeDisplayMode HomeNewsDisplayMode?
  homeSortOrder   Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([showOnHomePage, homePlacement, homeSortOrder])
}

model FaqItem {
  id         String   @id @default(cuid())
  question   String
  answerHtml String
  answerJson Json?
  sortOrder  Int      @default(0)
  isPublished Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublished, sortOrder, updatedAt])
}

model AboutSectionVersion {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  contentHtml String
  contentJson Json?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt, createdAt])
}

model TermsOfServiceVersion {
  id          String   @id @default(cuid())
  title       String
  contentHtml String
  contentJson Json?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt, createdAt])
}

model PrivacyPolicyVersion {
  id          String   @id @default(cuid())
  title       String
  contentHtml String
  contentJson Json?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt, createdAt])
}

model VideoHighlight {
  id                String          @id @default(cuid())
  title             String
  sourceType        VideoSourceType
  videoUrl          String
  showInCarousel    Boolean         @default(false)
  carouselSortOrder Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([showInCarousel, carouselSortOrder, updatedAt])
}

model Document {
  id                      String   @id @default(cuid())
  title                   String
  fileUrl                 String
  fileName                String?
  mimeType                String?
  sizeBytes               Int?
  showOnPublicDocumentsPage Boolean @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([title])
  @@index([showOnPublicDocumentsPage, updatedAt])
}

enum RegistrationStatus {
  ACTIVE
  INACTIVE
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum InvitationPurpose {
  ACCOUNT_SETUP
  PASSWORDLESS_LOGIN
}

enum AssignmentScopeType {
  GLOBAL
  LEAGUE
  SEASON
  TOURNAMENT
  PLAYER
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum ParticipantType {
  Singles
  Doubles
  Triples
  Teams
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentStageType {
  GROUP
  KNOCKOUT
}

enum StageRoundType {
  GROUP
  KNOCKOUT
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
  FORFEIT
  ABANDONED
}

enum MatchResultSubmissionStatus {
  PENDING
  APPROVED
  DISPUTED
}

enum ScheduleStatus {
  TBC
  CONFIRMED
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

