{
  "name": "nsl-platform",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "scripts": {
    "dev": "turbo dev --filter=@nsl/web",
    "build": "turbo build --filter=@nsl/web",
    "lint": "turbo lint --filter=@nsl/web",
    "expo": "npm --workspace=@nsl/mobile run start",
    "dev:web": "npm --workspace=@nsl/web run dev",
    "build:web": "npm --workspace=@nsl/web run build",
    "start:web": "npm --workspace=@nsl/web run start",
    "lint:web": "npm --workspace=@nsl/web run lint",
    "seed:web": "npm --workspace=@nsl/web run seed",
    "dev:mobile": "npm --workspace=@nsl/mobile run start",
    "android:mobile": "npm --workspace=@nsl/mobile run android",
    "ios:mobile": "npm --workspace=@nsl/mobile run ios",
    "web:mobile": "npm --workspace=@nsl/mobile run web"
  },
  "devDependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "turbo": "^2.5.0"
  }
}
